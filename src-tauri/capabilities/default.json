{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "platforms": ["linux", "macOS", "windows"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "core:webview:allow-print",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write-recursive",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-appconfig-write-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-applocaldata-read-recursive",
    "fs:allow-applocaldata-write-recursive",
    "fs:allow-applog-read-recursive",
    "fs:allow-applog-write-recursive",
    "fs:allow-desktop-read-recursive",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    "fs:allow-download-read-recursive",
    "fs:allow-download-write-recursive",
    "fs:allow-picture-read-recursive",
    "fs:allow-picture-write-recursive",
    "fs:allow-resource-read-recursive",
    "fs:allow-resource-write-recursive",
    "fs:allow-temp-read-recursive",
    "fs:allow-temp-write-recursive",
    "updater:default",
    "process:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$TEMP/**" },
        { "path": "$PICTURE/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "https://api.deepseek.com/*" },
        { "url": "https://api.siliconflow.cn/*" },
        { "url": "https://api.groq.com/*" },
        { "url": "https://openrouter.ai/*" },
        { "url": "https://dashscope.aliyuncs.com/*" },
        { "url": "https://open.bigmodel.cn/*" },
        { "url": "https://ark.cn-beijing.volces.com/*" },
        { "url": "https://api.minimax.io/*" },
        { "url": "https://api.moonshot.cn/*" },
        { "url": "https://api.x.ai/*" },
        { "url": "https://api.mistral.ai/*" },
        { "url": "https://aip.baidubce.com/*" },
        { "url": "https://api.together.xyz/*" },
        { "url": "https://api.fireworks.ai/*" },
        { "url": "https://api.cohere.ai/*" },
        { "url": "https://api.cohere.com/*" },
        { "url": "https://www.googleapis.com/*" },
        { "url": "https://serpapi.com/*" },
        { "url": "https://api.tavily.com/*" },
        { "url": "https://api.search.brave.com/*" },
        { "url": "https://open.bochaai.com/*" },
        { "url": "https://api.bochaai.com/*" },
        { "url": "https://arxiv.org/*" },
        { "url": "https://export.arxiv.org/*" },
        { "url": "https://api.openalex.org/*" },
        { "url": "https://api.unpaywall.org/*" },
        { "url": "https://doi.org/*" },
        { "url": "https://download.deepstudent.cn/*" },
        { "url": "https://www.deepstudent.cn/*" },
        { "url": "https://github.com/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://raw.githubusercontent.com/*" },
        { "url": "https://mcp.context7.com/*" },
        { "url": "https://context7.com/*" },
        { "url": "https://mcp.api-inference.modelscope.net/*" },
        { "url": "https://modelscope.cn/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" }
      ]
    }
  ]
}
