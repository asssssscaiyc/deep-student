{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "resources": {
      "resources/pdfium/libpdfium.dylib": "./"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Deep Student",
        "width": 1200,
        "height": 750,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": true,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "visible": true,
        "dragDropEnabled": true
      }
    ]
  }
}
